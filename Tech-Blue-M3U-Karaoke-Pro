<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Tech Blue • One Button (Spider 8 + Player + Queue + PiP + Card Logo)</title>
<meta name="color-scheme" content="dark">

<!-- HLS.js -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<style>
  :root{
    --accent:#1f8bff;
    --accent2:#4ac3ff;

    --ink:#eaf2ff;
    --muted:#a9c0ff;
    --line: rgba(255,255,255,.14);

    --desk: rgba(10,14,32,.10);

    --btnW: 360px;
    --btnH: 98px;
    --round: 22px;

    --orb: 56px;
    --radius: 160px;
    --drawerW: 480px;
    --shadow: 0 22px 80px rgba(0,0,0,.6);
  }

  *{box-sizing:border-box}
  html,body{height:100%}
  body{margin:0;background:transparent;overflow:hidden}

  body::before{
    content:"";
    position:fixed; inset:-40px;
    background:
      radial-gradient(820px 420px at 50% 45%, color-mix(in oklab, var(--desk) 75%, transparent), transparent 62%),
      radial-gradient(520px 280px at 35% 35%, color-mix(in oklab, var(--accent) 14%, transparent), transparent 64%),
      radial-gradient(520px 280px at 65% 65%, color-mix(in oklab, var(--accent2) 10%, transparent), transparent 64%);
    pointer-events:none;
    filter: blur(10px);
    opacity:.95;
  }

  .stage{position:fixed; inset:0; display:grid; place-items:center; padding:24px;}

  .core{
    position:relative;
    width:var(--btnW); height:var(--btnH);
    border-radius:var(--round);
    border:1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03)),
      radial-gradient(420px 160px at 20% 0%, color-mix(in oklab, var(--accent) 26%, transparent), transparent 58%),
      radial-gradient(420px 160px at 80% 120%, color-mix(in oklab, var(--accent2) 18%, transparent), transparent 58%),
      rgba(0,0,0,.14);
    backdrop-filter: blur(14px);
    box-shadow: var(--shadow);
    cursor:pointer; user-select:none;
    display:flex; align-items:center; justify-content:space-between;
    padding:14px 14px 14px 16px; gap:10px;
    transform: translateZ(0);
  }

  /* ===== Card background overlay (image bg mode) ===== */
  .coreBgOverlay{
    position:absolute;
    inset:0;
    border-radius: var(--round);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: .35;
    pointer-events:none;
    filter: saturate(1.05) contrast(1.05);
    mix-blend-mode: screen;
  }

  .left{display:flex; align-items:center; gap:10px; min-width:0;}
  .logo{
    width:44px;height:44px;border-radius:16px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border:1px solid rgba(255,255,255,.18);
    box-shadow: 0 14px 30px color-mix(in oklab, var(--accent) 24%, transparent);
    flex:0 0 auto;
    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;
  }
  .txt{min-width:0}
  .txt b{display:block;color:var(--ink);font-size:14px;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .txt small{display:block;color:var(--muted);font-size:12px;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

  .actions{display:flex; gap:8px; align-items:center; flex:0 0 auto;}
  .chip{
    border:1px solid rgba(255,255,255,.14);
    background: rgba(94, 93, 93, 0.546);
    color: var(--ink);
    padding:9px 10px;
    border-radius:14px;
    font-size:12px;
    cursor:pointer;
  }
  .chip:active{ transform: translateY(1px); }

  /* spider */
  .spider{position:absolute; left:50%; top:50%; width:1px; height:1px; pointer-events:none;}
  .leg{
    position:absolute; left:50%; top:50%;
    height:2px; transform-origin:left center;
    opacity:0; width:0;
    background: linear-gradient(90deg, rgba(31,139,255,.0), rgba(31,139,255,.55), rgba(74,195,255,.22));
    filter: drop-shadow(0 0 10px rgba(31,139,255,.25));
    transition: width .28s ease, opacity .28s ease;
  }
  .node{
    position:absolute; width:56px; height:56px;
    border-radius:18px;
    transform: translate(-50%,-50%) scale(.72);
    opacity:0;
    pointer-events:auto;
    display:grid; place-items:center;
    border:1px solid rgba(255,255,255,.14);
    background:
      radial-gradient(120px 70px at 30% 30%, rgba(255,255,255,.10), transparent 60%),
      rgba(12,18,44,.85);
    box-shadow: 0 18px 45px rgba(0,0,0,.45);
    transition: transform .28s ease, opacity .28s ease, filter .28s ease;
    backdrop-filter: blur(10px);
  }
  .node:hover{ filter: brightness(1.12); transform: translate(var(--tx), var(--ty)) translate(-50%,-50%) scale(.80); }
  .node i{font-style:normal;font-size:20px;}
  .nodeLabel{
    position:absolute; top:calc(100% + 8px); left:50%;
    transform:translateX(-50%);
    font-size:11px; color:rgba(233,242,255,.9);
    padding:6px 8px; border-radius:999px;
    border:1px solid rgba(255,255,255,.12);
    background: rgba(0,0,0,.22);
    white-space:nowrap;
  }

  .node[data-a="0"]   { --ux:  0;    --uy: -1; }
  .node[data-a="45"]  { --ux:  0.707;--uy: -0.707; }
  .node[data-a="90"]  { --ux:  1;    --uy:  0; }
  .node[data-a="135"] { --ux:  0.707;--uy:  0.707; }
  .node[data-a="180"] { --ux:  0;    --uy:  1; }
  .node[data-a="225"] { --ux: -0.707;--uy:  0.707; }
  .node[data-a="270"] { --ux: -1;    --uy:  0; }
  .node[data-a="315"] { --ux: -0.707;--uy: -0.707; }

  .open .node{
    opacity:1;
    --tx: calc(var(--ux) * var(--radius));
    --ty: calc(var(--uy) * var(--radius));
    transform: translate(var(--tx), var(--ty)) translate(-50%,-50%) scale(.78);
  }
  .open .leg{ opacity:1; width: calc(var(--radius) - 22px); }

  .leg[data-a="0"]   { transform: translate(0,-1px) rotate(-90deg); }
  .leg[data-a="45"]  { transform: translate(0,-1px) rotate(-45deg); }
  .leg[data-a="90"]  { transform: translate(0,-1px) rotate( 0deg); }
  .leg[data-a="135"] { transform: translate(0,-1px) rotate( 45deg); }
  .leg[data-a="180"] { transform: translate(0,-1px) rotate( 90deg); }
  .leg[data-a="225"] { transform: translate(0,-1px) rotate(135deg); }
  .leg[data-a="270"] { transform: translate(0,-1px) rotate(180deg); }
  .leg[data-a="315"] { transform: translate(0,-1px) rotate(-135deg); }

  /* drawer */
  .drawer{
    position:fixed; top:50%; right:18px;
    transform: translateY(-50%);
    width:min(var(--drawerW), calc(100vw - 36px));
    max-height: min(86vh, 820px);
    overflow:auto;
    border-radius:22px;
    border:1px solid rgba(255,255,255,.14);
    background:
      radial-gradient(560px 240px at 15% 0%, rgba(31,139,255,.18), transparent 60%),
      rgba(10,14,32,.86);
    box-shadow: 0 30px 90px rgba(0,0,0,.65);
    backdrop-filter: blur(12px);
    display:none; z-index:20;
  }
  .drawer.show{ display:block; }
  .dTop{
    position:sticky; top:0;
    padding:12px;
    display:flex; align-items:center; justify-content:space-between; gap:10px;
    border-bottom:1px solid rgba(255,255,255,.10);
    background: rgba(10,14,32,.80);
    backdrop-filter: blur(12px);
  }
  .dTop b{ font-size:13px; color:rgba(233,242,255,.95); }
  .xbtn{
    border:1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color:var(--ink);
    border-radius:12px;
    padding:9px 10px;
    cursor:pointer;
  }
  .dBody{ padding:12px; display:grid; gap:10px; }

  .card{
    border:1px solid rgba(255,255,255,.10);
    background: rgba(255,255,255,.04);
    border-radius:18px;
    padding:12px;
  }
  .card h3{ margin:0 0 6px 0; font-size:12px; }
  .card p{ margin:0 0 10px 0; font-size:12px; color:var(--muted); line-height:1.35; }

  input,textarea{
    width:100%;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.14);
    background: rgba(0,0,0,.22);
    color:var(--ink);
    padding:10px 12px;
    outline:none;
    font-size:13px;
  }
  textarea{ min-height:120px; resize:vertical; }

  .row{ display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:10px 12px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.14);
    background: rgba(31,139,255,.12);
    color:var(--ink);
    cursor:pointer;
    font-size:13px;
  }
  .btn.secondary{ background: rgba(255,255,255,.06); }
  .btn.good{ background: rgba(32,201,151,.14); }
  .btn.bad{ background: rgba(239,71,111,.14); }

  .list{ display:grid; gap:8px; max-height:320px; overflow:auto; padding-right:4px; }
  .item{
    border:1px solid rgba(255,255,255,.10);
    background: rgba(0,0,0,.18);
    border-radius:16px;
    padding:10px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
  }
  .item small{ display:block; color:var(--muted); margin-top:2px; }
  .tag{
    font-size:11px;
    padding:6px 8px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color:rgba(233,242,255,.9);
    white-space:nowrap;
  }

  /* player */
  .playerWrap{
    border:1px solid rgba(255,255,255,.10);
    border-radius:16px;
    overflow:hidden;
    background: rgba(0,0,0,.20);
  }
  video{ width:100%; height:auto; display:block; background:#000; }
  .now{ font-size:12px; color:rgba(233,242,255,.9); margin:0; }
  .mono{
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size:11px; color:var(--muted);
    word-break: break-all;
    margin:6px 0 0 0;
  }

  /* toast */
  .toast{
    position:fixed;
    left:50%; bottom:16px;
    transform:translateX(-50%);
    background: rgba(0,0,0,.55);
    border:1px solid rgba(255,255,255,.14);
    color:var(--ink);
    border-radius:999px;
    padding:10px 12px;
    font-size:12px;
    display:none;
    z-index:60;
    backdrop-filter: blur(10px);
  }
  .toast.show{ display:block; }

  /* ===== PiP Floating ===== */
  .pip{
    position:fixed;
    left: 22px;
    bottom: 22px;
    width: 380px;
    max-width: calc(100vw - 44px);
    border-radius:18px;
    border:1px solid rgba(255,255,255,.14);
    background:
      radial-gradient(520px 220px at 15% 0%, rgba(31,139,255,.18), transparent 60%),
      rgba(10,14,32,.88);
    box-shadow: 0 30px 90px rgba(0,0,0,.70);
    backdrop-filter: blur(12px);
    display:none;
    z-index:80;
    overflow:hidden;
  }
  .pip.show{ display:block; }

  .pipHead{
    padding:10px 10px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    border-bottom:1px solid rgba(255,255,255,.10);
    cursor: grab;
    user-select:none;
  }
  .pipHead:active{ cursor: grabbing; }
  .pipTitle{
    min-width:0;
    color:rgba(233,242,255,.95);
    font-size:12px;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }
  .pipBtns{ display:flex; gap:8px; flex:0 0 auto; }
  .pipBtn{
    border:1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color:var(--ink);
    border-radius:12px;
    padding:7px 9px;
    cursor:pointer;
    font-size:12px;
  }
  .pipBody{ padding:10px; }
</style>
</head>
<body>

<div class="stage">
  <div class="core" id="core" role="button" tabindex="0">
    <div class="left">
      <div class="logo" id="coreLogo" title="Click para cambiar logo"></div>
      <div class="txt">
        <b>Tech Blue • One Button</b>
        <small>Click/Enter: araña • Esc: cerrar</small>
      </div>
    </div>
    <div class="actions">
      <button class="chip" id="pickDesk" title="Clonar color del desktop"></button>
      <button class="chip" id="toggle" title="Abrir/Cerrar araña"></button>
    </div>

    <div class="spider" id="spider">
      <div class="leg" data-a="0"></div><div class="leg" data-a="45"></div><div class="leg" data-a="90"></div><div class="leg" data-a="135"></div>
      <div class="leg" data-a="180"></div><div class="leg" data-a="225"></div><div class="leg" data-a="270"></div><div class="leg" data-a="315"></div>

      <div class="node" data-a="0"   data-mod="player"><i>🎬</i><div class="nodeLabel">Player</div></div>
      <div class="node" data-a="45"  data-mod="fav"><i>⭐</i><div class="nodeLabel">Fav</div></div>
      <div class="node" data-a="90"  data-mod="m3u"><i>📺</i><div class="nodeLabel">M3U</div></div>
      <div class="node" data-a="135" data-mod="links"><i>🔗</i><div class="nodeLabel">Links</div></div>
      <div class="node" data-a="180" data-mod="look"><i>🎨</i><div class="nodeLabel">Look</div></div>
      <div class="node" data-a="225" data-mod="social"><i>🌐</i><div class="nodeLabel">Social</div></div>
      <div class="node" data-a="270" data-mod="ai"><i>🤖</i><div class="nodeLabel">AI</div></div>
      <div class="node" data-a="315" data-mod="sys"><i>⚙️</i><div class="nodeLabel">Sys</div></div>
    </div>
  </div>
</div>

<div class="drawer" id="drawer" aria-hidden="true">
  <div class="dTop">
    <b id="dTitle">Módulo</b>
    <button class="xbtn" id="dClose">Cerrar ✕</button>
  </div>
  <div class="dBody" id="dBody"></div>
</div>

<!-- PiP Floating Container -->
<div class="pip" id="pip">
  <div class="pipHead" id="pipHead">
    <div class="pipTitle" id="pipTitle">PiP • —</div>
    <div class="pipBtns">
      <button class="pipBtn" id="pipUnmute">🔊</button>
      <button class="pipBtn" id="pipStop">⏹️</button>
      <button class="pipBtn" id="pipDock">📎</button>
      <button class="pipBtn" id="pipClose">✕</button>
    </div>
  </div>
  <div class="pipBody">
    <div class="playerWrap" id="pipSlot"></div>
  </div>
</div>

<div class="toast" id="toast">Listo</div>

<script>
  const $ = (q, el=document)=> el.querySelector(q);
  const $$ = (q, el=document)=> Array.from(el.querySelectorAll(q));

  const toastEl = $("#toast");
  function toast(msg){
    toastEl.textContent = msg;
    toastEl.classList.add("show");
    clearTimeout(window.__t);
    window.__t = setTimeout(()=>toastEl.classList.remove("show"), 1400);
  }

  function esc(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }
  function hexToRgba(hex, a){
    const h = hex.replace("#","");
    const r = parseInt(h.slice(0,2),16);
    const g = parseInt(h.slice(2,4),16);
    const b = parseInt(h.slice(4,6),16);
    return `rgba(${r},${g},${b},${a})`;
  }
  function isHlsUrl(url){ return /\.m3u8(\?|#|$)/i.test(url || ""); }
  function isMediaUrl(url){ return /\.(mp4|webm|ogg)(\?|#|$)/i.test(url || "") || isHlsUrl(url); }

  const KEY = "tb_onebutton_full_v1";
  const defaultState = {
    accent:"#1f8bff",
    accent2:"#4ac3ff",
    desk:"rgba(10,14,32,.10)",

    playerUrl:"",
    nowPlaying:{ name:"", url:"" },

    queue:[],
    autoNext:true,

    pipOn:false,

    // ===== Card image settings =====
    cardLogoDataUrl:"",
    cardLogoMode:"icon",     // "icon" | "bg"
    cardBgOpacity:0.35,      // 0.10..0.70

    playlists:[ {name:"Demo", url:"https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8"} ],
    links:[ {name:"Mi TV Station", url:"https://cuervo-123.github.io/mi-tv-station-v-10.3/"} ],
    socials:[
  {name:"YouTube", url:"https://youtube.com"},
  {name:"M3U Builder Tech blue Karaoke Pro", url:"https://cuervo-123.github.io/M3U-Builder-Tech-blue-Karaoke-Pro/"},
  {name:"Mi TV Station", url:"https://cuervo-123.github.io/mi-tv-station-v-10.3/"}
],
     favs:[]
  };

  const state = loadState() || defaultState;

  function loadState(){ try{ return JSON.parse(localStorage.getItem(KEY)); }catch(e){ return null; } }
  function saveState(silent=false){
    localStorage.setItem(KEY, JSON.stringify(state));
    applyTheme();
    if(!silent) toast("Guardado ✅");
  }
  function applyTheme(){
    document.documentElement.style.setProperty("--accent", state.accent);
    document.documentElement.style.setProperty("--accent2", state.accent2);
    document.documentElement.style.setProperty("--desk", state.desk);
  }
  applyTheme();

  // ===== Core refs =====
  const core = $("#core");
  const coreLogo = $("#coreLogo");

  // ===== Card Logo system =====
  let bgOverlay = null;
  function ensureBgOverlay(){
    if(bgOverlay) return bgOverlay;
    bgOverlay = document.createElement("div");
    bgOverlay.className = "coreBgOverlay";
    core.insertBefore(bgOverlay, core.firstChild);
    return bgOverlay;
  }

  function applyCardLogo(){
    const img = state.cardLogoDataUrl || "";
    const mode = state.cardLogoMode || "icon";
    const op = typeof state.cardBgOpacity === "number" ? state.cardBgOpacity : 0.35;

    if(mode === "icon"){
      // icon
      if(img){
        coreLogo.style.backgroundImage = `url('${img}')`;
      }else{
        coreLogo.style.backgroundImage = "";
        coreLogo.style.background = "linear-gradient(135deg, var(--accent), var(--accent2))";
      }
      // bg off
      if(bgOverlay) bgOverlay.style.backgroundImage = "";
      return;
    }

    // background mode
    if(img){
      const ov = ensureBgOverlay();
      ov.style.backgroundImage = `url('${img}')`;
      ov.style.opacity = String(op);

      // keep icon as gradient (identity)
      coreLogo.style.backgroundImage = "";
      coreLogo.style.background = "linear-gradient(135deg, var(--accent), var(--accent2))";
    }else{
      if(bgOverlay) bgOverlay.style.backgroundImage = "";
    }
  }

  // hidden input for image upload
  const cardFile = document.createElement("input");
  cardFile.type = "file";
  cardFile.accept = "image/*";
  cardFile.style.display = "none";
  document.body.appendChild(cardFile);

  function openCardImagePicker(){
    cardFile.value = "";
    cardFile.click();
  }

  function fileToDataUrl(file){
    return new Promise((resolve, reject)=>{
      const r = new FileReader();
      r.onload = ()=> resolve(String(r.result || ""));
      r.onerror = reject;
      r.readAsDataURL(file);
    });
  }

  // Resize helper to keep localStorage light
  function resizeImageDataUrl(dataUrl, maxSide=512){
    return new Promise((resolve, reject)=>{
      const img = new Image();
      img.onload = ()=>{
        const w = img.width, h = img.height;
        const scale = Math.min(1, maxSide / Math.max(w,h));
        const nw = Math.max(1, Math.round(w*scale));
        const nh = Math.max(1, Math.round(h*scale));

        const c = document.createElement("canvas");
        c.width = nw; c.height = nh;
        const ctx = c.getContext("2d");
        ctx.drawImage(img, 0, 0, nw, nh);

        try{
          resolve(c.toDataURL("image/webp", 0.86));
        }catch(e){
          resolve(c.toDataURL("image/png"));
        }
      };
      img.onerror = reject;
      img.src = dataUrl;
    });
  }

  cardFile.addEventListener("change", async ()=>{
    const file = cardFile.files && cardFile.files[0];
    if(!file) return;

    const dataUrl = await fileToDataUrl(file);
    try{
      state.cardLogoDataUrl = await resizeImageDataUrl(dataUrl, 512);
    }catch(_){
      state.cardLogoDataUrl = dataUrl;
    }
    saveState(true);
    applyCardLogo();
    toast("Logo cargado ✅");
    // refresh Look module if it's open
    if ($("#dTitle")?.textContent?.includes("Look")) renderLook();
  });

  coreLogo.addEventListener("click", (e)=>{
    e.stopPropagation();
    openCardImagePicker();
  });

  applyCardLogo();

  // ===== Spider open/close =====
  $("#toggle").addEventListener("click",(e)=>{ e.stopPropagation(); core.classList.toggle("open"); });
  core.addEventListener("click",(e)=>{
    if(e.target.closest(".node") || e.target.closest("button")) return;
    core.classList.toggle("open");
  });

  document.addEventListener("keydown",(e)=>{
    if(e.key==="Escape"){ core.classList.remove("open"); hideDrawer(); }
  });

  // ===== Drawer =====
  const drawer = $("#drawer");
  const dTitle = $("#dTitle");
  const dBody  = $("#dBody");
  $("#dClose").addEventListener("click", hideDrawer);

  function showDrawer(title){
    dTitle.textContent = title;
    drawer.classList.add("show");
    drawer.setAttribute("aria-hidden","false");
  }
  function hideDrawer(){
    drawer.classList.remove("show");
    drawer.setAttribute("aria-hidden","true");
  }

  // ===== PiP =====
  const pip = $("#pip");
  const pipHead = $("#pipHead");
  const pipSlot = $("#pipSlot");
  const pipTitle = $("#pipTitle");
  let pipDrag = {on:false, dx:0, dy:0};

  function showPiP(){
    pip.classList.add("show");
    state.pipOn = true;
    saveState(true);
    updatePipTitle();
  }
  function hidePiP(){
    pip.classList.remove("show");
