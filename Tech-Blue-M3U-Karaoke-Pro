  pipHead.addEventListener("pointerdown",(e)=>{
    if(e.target.closest("button")) return;
    pipDrag.on = true;
    const rect = pip.getBoundingClientRect();
    pipDrag.dx = e.clientX - rect.left;
    pipDrag.dy = e.clientY - rect.top;
    pipHead.setPointerCapture(e.pointerId);
  });
  pipHead.addEventListener("pointermove",(e)=>{
    if(!pipDrag.on) return;
    const x = e.clientX - pipDrag.dx;
    const y = e.clientY - pipDrag.dy;
    pip.style.left = Math.max(8, Math.min(window.innerWidth - pip.offsetWidth - 8, x)) + "px";
    pip.style.top  = Math.max(8, Math.min(window.innerHeight - pip.offsetHeight - 8, y)) + "px";
    pip.style.bottom = "auto";
  });
  pipHead.addEventListener("pointerup",()=>{ pipDrag.on=false; });
  pipHead.addEventListener("pointercancel",()=>{ pipDrag.on=false; });

