          <button class="btn good" id="cardUpload">🖼️ Cargar imagen</button>
          <button class="btn bad" id="cardClear">🗑️ Quitar</button>
        </div>

        <div class="row" style="margin-top:10px">
          <button class="btn ${state.cardLogoMode==="icon"?"good":"secondary"}" id="modeIcon">🧩 Icon</button>
          <button class="btn ${state.cardLogoMode==="bg"?"good":"secondary"}" id="modeBg">🖼️ Background</button>
        </div>

        <label style="display:block;margin-top:10px;font-size:12px;color:var(--muted)">
          Opacidad del fondo: <span id="opVal">${Number(state.cardBgOpacity||0.35).toFixed(2)}</span>
        </label>
        <input id="bgOp" type="range" min="0.10" max="0.70" step="0.01" value="${esc(String(state.cardBgOpacity ?? 0.35))}">
      </div>
    `;

    $("#apply").onclick=()=>{ state.accent=$("#a1").value; state.accent2=$("#a2").value; applyTheme(); toast("Aplicado ✨"); };
    $("#save").onclick=()=>{ state.accent=$("#a1").value; state.accent2=$("#a2").value; saveState(); };
    $("#pick").onclick=()=>$("#pickDesk").click();

    $("#cardUpload").onclick=()=> openCardImagePicker();
    $("#cardClear").onclick=()=>{
      state.cardLogoDataUrl = "";
      saveState(true);
      applyCardLogo();
      toast("Logo removido ✅");
      renderLook();
    };

    $("#modeIcon").onclick=()=>{
      state.cardLogoMode = "icon";
      saveState(true);
      applyCardLogo();
      renderLook();
    };

    $("#modeBg").onclick=()=>{
      state.cardLogoMode = "bg";
      saveState(true);
      applyCardLogo();
      renderLook();
    };

    const bgOp = $("#bgOp");
    bgOp.oninput = ()=>{
      state.cardBgOpacity = Number(bgOp.value);
      $("#opVal").textContent = Number(state.cardBgOpacity).toFixed(2);
      saveState(true);
      applyCardLogo();
    };
  }

  function renderSocial(){
    dBody.innerHTML=`
      <div class="card">
        <h3>Social</h3>
        <div class="list">
          ${(state.socials||[]).map(s=>`
            <div class="item">
              <div style="min-width:0">
                <b style="font-size:12px">${esc(s.name||"Social")}</b>
                <small>${esc(s.url)}</small>
              </div>
              <div class="row">
                <a class="btn secondary" href="${esc(s.url)}" target="_blank" rel="noopener">Abrir</a>
              </div>
            </div>
          `).join("")}
        </div>
      </div>
    `;
  }

  function renderAI(){
    dBody.innerHTML=`
      <div class="card">
        <h3>AI (placeholder)</h3>
        <p>Slot listo para conectar API luego.</p>
        <textarea placeholder="Prompt..."></textarea>
      </div>
    `;
  }

  function renderSys(){
    dBody.innerHTML=`
      <div class="card">
        <h3>Export / Reset</h3>
        <div class="row">
          <button class="btn" id="exp">Export</button>
          <button class="btn secondary" id="wipe">Reset</button>
        </div>
        <textarea id="box" style="margin-top:10px" placeholder="JSON..."></textarea>
      </div>
    `;
    $("#exp").onclick=()=>{
      $("#box").value = JSON.stringify(state, null, 2);
      $("#box").focus(); $("#box").select();
      toast("Exportado ✅");
    };
    $("#wipe").onclick=()=>{
      localStorage.removeItem(KEY);
      toast("Reset (recarga)");
      setTimeout(()=>location.reload(), 700);
    };
  }

  // ===== restore PiP state on load =====
  if(state.pipOn){
    pip.classList.add("show");
    updatePipTitle();
  }

  // ===== Apply card logo on load =====
  applyCardLogo();
</script>

</body>
</html>
