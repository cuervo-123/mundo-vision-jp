  // ===== inline player engine =====
  let hlsInstance = null;
  function destroyHls(){ if(hlsInstance){ try{ hlsInstance.destroy(); }catch(_){} hlsInstance=null; } }

  function ensureVideo(){ return document.getElementById("tbVideo") || null; }
  function getDockSlot(){ return document.getElementById("dockSlot") || null; }

  function ensureVideoExists(){
    let v = ensureVideo();
    if(v) return v;

    v = document.createElement("video");
    v.id = "tbVideo";
    v.setAttribute("controls","");
    v.setAttribute("playsinline","");
    v.style.width = "100%";
    v.style.height = "auto";
    v.style.display = "block";
    v.style.background = "#000";

    v.addEventListener("ended", ()=>{
      if(state.autoNext) playNextFromQueue();
    });

    return v;
  }

  function dockToPiP(){
    const v = ensureVideoExists();
    pipSlot.innerHTML = "";
    pipSlot.appendChild(v);
    showPiP();
    updatePipTitle();
  }

  function dockToDrawer(){
    const slot = getDockSlot();
    const v = ensureVideo();
    if(!slot || !v){
      hidePiP();
      return;
    }
    slot.innerHTML = "";
    slot.appendChild(v);
    hidePiP();
  }

  function autoDockVideo(){
    const v = ensureVideo();
    if(!v) return;
    if(state.pipOn){
      pipSlot.innerHTML = "";
      pipSlot.appendChild(v);
      pip.classList.add("show");
      updatePipTitle();
    }else{
      const slot = getDockSlot();
      if(slot){
        slot.innerHTML = "";
        slot.appendChild(v);
      }
      pip.classList.remove("show");
    }
  }

  function waitForCanPlay(video, ms=2500){
    return new Promise((resolve, reject)=>{
      let done=false;
      const t=setTimeout(()=>{ if(done) return; done=true; cleanup(); reject(new Error("timeout")); }, ms);
      function cleanup(){
        clearTimeout(t);
        video.removeEventListener("canplay", on);
        video.removeEventListener("loadedmetadata", on);
      }
      function on(){ if(done) return; done=true; cleanup(); resolve(); }
      video.addEventListener("canplay", on, {once:true});
      video.addEventListener("loadedmetadata", on, {once:true});
    });
  }

  async function playInline(url, name=""){
    url = (url||"").trim();
    if(!url) return toast("URL vacía");

    state.nowPlaying = { name: name || "Now Playing", url };
    state.playerUrl = url;
    saveState(true);
    updatePipTitle();

    const v = ensureVideoExists();

    if(state.pipOn) dockToPiP();
    else autoDockVideo();

    try{
      destroyHls();
      v.pause();
      v.removeAttribute("src");
      v.load();

      // MUTED at start ✅
      v.muted = true;

      const isHls = isHlsUrl(url);

      if(isHls){
        if(window.Hls && Hls.isSupported()){
          hlsInstance = new Hls({ enableWorker:true, lowLatencyMode:true });
          hlsInstance.loadSource(url);
          hlsInstance.attachMedia(v);
          hlsInstance.on(Hls.Events.ERROR, function(_, data){
            if(data?.fatal){
              toast("Error HLS fatal ❌");
              destroyHls();
            }
          });
          await waitForCanPlay(v, 3000).catch(()=>{});
          await v.play().catch(()=>{});
        }else if(v.canPlayType("application/vnd.apple.mpegurl")){
          v.src = url;
          await waitForCanPlay(v, 3000).catch(()=>{});
          await v.play().catch(()=>{});
        }else{
          toast("Este navegador no reproduce .m3u8 ❌");
          return;
        }
      }else{
        v.src = url;
        await waitForCanPlay(v, 3000).catch(()=>{});
        await v.play().catch(()=>{});
      }

      const nowName = document.getElementById("nowName");
      const nowUrl  = document.getElementById("nowUrl");
      if(nowName) nowName.textContent = state.nowPlaying.name || "Now Playing";
      if(nowUrl)  nowUrl.textContent  = state.nowPlaying.url || "";

      toast("Reproduciendo (muted) ▶️");
    }catch(e){
      toast("No se pudo reproducir ❌");
    }
  }

  function stopInline(){
    const v = ensureVideo();
    destroyHls();
    if(v){
      try{ v.pause(); }catch(_){}
      try{ v.removeAttribute("src"); v.load(); }catch(_){}
    }
    toast("Stop ⏹️");
  }

  // ===== Queue =====
  function addToQueue(item, mode="end"){
    state.queue = state.queue || [];
    const obj = { ...item, id: crypto.randomUUID?.() || String(Date.now()+Math.random()) };
    if(mode==="next") state.queue.unshift(obj);
    else state.queue.push(obj);
    saveState(true);
    toast(mode==="next" ? "Añadido Next ⏭️" : "Añadido a Queue ✅");
  }
  function removeFromQueue(idx){
    state.queue.splice(idx,1);
    saveState(true);
  }
  function shuffleQueue(){
    const a = state.queue || [];
    for(let i=a.length-1;i>0;i--){
      const j = Math.floor(Math.random()*(i+1));
      [a[i],a[j]]=[a[j],a[i]];
    }
    saveState(true);
  }
  function playNextFromQueue(){
    state.queue = state.queue || [];
    if(state.queue.length===0){ toast("Queue vacía"); return; }
    const next = state.queue.shift();
    saveState(true);
    playInline(next.url, next.name || "Queue");
    if(document.getElementById("qList")) renderQueueSection();
  }

